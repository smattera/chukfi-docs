---
// src/components/Unveiling.astro — Product unveiling page with parallax engine
import Logo from '../assets/logo.svg';
---
<div class="glow-orb glow-orb-1"></div>
<div class="glow-orb glow-orb-2"></div>

<div class="unveiling-hero">
  <div class="unveiling-badge">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
    CHUKFI CMS v0.2.0 IS LIVE
  </div>

  <div class="hero-logo-container">
    <div class="hero-logo-glow"></div>
    <Logo class="hero-logo-svg" />
  </div>

  <h1 class="unveiling-title">
    Ship a CMS in Minutes.<br/>
    <span style="color: var(--sl-color-accent-high);">Manage it with AI.</span>
  </h1>
  <p style="margin: 0 auto 3rem; font-size: 1.3rem; opacity: 0.8; max-width: 700px; line-height: 1.6; color: var(--sl-color-gray-1);">
    The zero-dependency, CLI-first headless CMS built in Rust for solo developers who want production-grade parity without managing infrastructure.
  </p>

  <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
    <a href="/guides/quick-start/" class="unveiling-cta unveiling-cta-primary">
      Get Started
    </a>
    <a href="/guides/overview/" class="unveiling-cta">
      Read Architecture
    </a>
  </div>
</div>

<div class="isometric-container">
  <div class="isometric-stack">
    <div class="stack-layer layer-frontend">
      <div class="layer-content">
        <div class="layer-title" style="color: var(--sl-color-accent);">ASTRO 7</div>
        <div class="layer-subtitle">Type-Safe Client Islands</div>
      </div>
    </div>
    <div class="stack-layer layer-core">
      <div class="layer-content">
        <div class="layer-title" style="color: var(--chukfi-accent);">RUST CORE</div>
        <div class="layer-subtitle">Axum API &middot; Zero Runtime Deps</div>
      </div>
    </div>
    <div class="stack-layer layer-infra">
      <div class="layer-content">
        <div class="layer-title" style="color: #94a3b8;">AWS + PG</div>
        <div class="layer-subtitle">ECS Fargate &middot; RDS Postgres</div>
      </div>
    </div>
  </div>
</div>

<div class="statement-section">
  <div class="statement-grid">
    <div>
      <h2 class="statement-huge">CLI-First.<br/>Zero Toolchains.</h2>
    </div>
    <div>
      <p style="font-size: 1.15rem; line-height: 1.7; opacity: 0.8; margin: 0; color: var(--sl-color-gray-1);">
        No Rust environment, no compilation wait times, no Docker Compose templates to copy-paste.
        <code>npx chukfi dev</code> spins up a local PostgreSQL engine, applies migrations, and launches your API in under 5 seconds.
      </p>
    </div>
  </div>
</div>

<div class="statement-section">
  <div class="statement-grid">
    <div>
      <div class="unveiling-badge" style="margin-bottom: 1.5rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        TEAMS + AWS BEDROCK + CLAUDE
      </div>
      <h2 class="statement-huge">Chat to Publish.</h2>
      <p style="font-size: 1.15rem; line-height: 1.7; opacity: 0.8; margin: 0 0 1rem; color: var(--sl-color-gray-1);">
        Staff can create, edit, and schedule content directly from Microsoft Teams. Chukfi connects to AWS Bedrock running Claude to draft posts, rewrite copy, and generate metadata &mdash; all from a chat thread.
      </p>
      <p style="font-size: 1rem; opacity: 0.7; color: var(--sl-color-accent-high); margin: 0;">
        Every AI change is forced to <strong>draft</strong>. Human approval is hardcoded &mdash; not a prompt, not a suggestion.
      </p>
    </div>
    <div class="teams-mockup">
      <div class="teams-header">
        <div class="teams-dots">
          <span class="teams-dot teams-dot-red"></span>
          <span class="teams-dot teams-dot-yellow"></span>
          <span class="teams-dot teams-dot-green"></span>
        </div>
        <span class="teams-title">Chukfi CMS Bot</span>
        <span class="teams-status">
          <span class="teams-online"></span> Online
        </span>
      </div>
      <div class="teams-messages">
        <div class="teams-msg teams-msg-user">
          <div class="teams-avatar">JD</div>
          <div class="teams-bubble">
            <strong>Jane (Editor)</strong>
            <p>Create a blog post about our new donation matching program with the Choctaw Nation. Include a header image, a quote from Chief Standingbear, and a CTA for volunteering.</p>
          </div>
        </div>
        <div class="teams-msg teams-msg-bot">
          <div class="teams-avatar teams-avatar-bot">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/></svg>
          </div>
          <div class="teams-bubble teams-bubble-bot">
            <div class="teams-typing">
              <span></span><span></span><span></span>
            </div>
          </div>
        </div>
        <div class="teams-msg teams-msg-bot">
          <div class="teams-avatar teams-avatar-bot">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/></svg>
          </div>
          <div class="teams-bubble teams-bubble-bot">
            <strong>Chukfi CMS Bot</strong>
            <div class="teams-draft-card">
              <div class="teams-draft-badge">DRAFT &mdash; Awaiting Approval</div>
              <div class="teams-draft-title">Choctaw Nation Donation Match: $50K Grant Expands Tribal Services</div>
              <div class="teams-draft-meta"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>Header image selected &middot; 850 words &middot; 3 citations</div>
              <div class="teams-draft-actions">
                <span class="teams-draft-btn teams-draft-approve"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align: middle; margin-right: 3px;"><polyline points="20 6 9 17 4 12"/></svg>Approve</span>
                <span class="teams-draft-btn teams-draft-edit"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 3px;"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>Edit</span>
                <span class="teams-draft-btn teams-draft-reject"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align: middle; margin-right: 3px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Reject</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="statement-section">
  <div class="statement-grid">
    <div class="fb-mockup">
      <div class="fb-card">
        <div class="fb-card-header">
          <div class="fb-avatar">N</div>
          <div>
            <div class="fb-name">Native Consulting Services</div>
            <div class="fb-time">Just now &middot; <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 2px;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
          </div>
        </div>
        <div class="fb-card-body">
          Breaking ground on the new Tribal digital services platform in partnership with the Mississippi Band of Choctaw Indians. Read about the $2.3M infrastructure investment and what it means for rural broadband access across the reservation.
        </div>
        <div class="fb-card-preview">
          <div class="fb-card-preview-img">
            <svg width="100%" height="100%" viewBox="0 0 400 200" fill="none"><rect width="400" height="200" rx="4" fill="#1e293b"/><rect x="140" y="60" width="120" height="80" rx="8" fill="#334155"/><line x1="160" y1="100" x2="240" y2="100" stroke="#64748b" stroke-width="2"/><line x1="160" y1="110" x2="225" y2="110" stroke="#64748b" stroke-width="2"/><circle cx="200" cy="80" r="10" fill="#60a5fa" opacity="0.3"/></svg>
          </div>
          <div class="fb-card-preview-text">
            <div class="fb-card-preview-domain">chukfi.dev</div>
            <div class="fb-card-preview-title">$2.3M Tribal Broadband Investment &mdash; MBCI Infrastructure Initiative</div>
            <div class="fb-card-preview-desc">Phase 1 delivers fiber to 2,400 homes across 6 communities. Full coverage expected by Q3 2027.</div>
          </div>
        </div>
        <div class="fb-card-actions">
          <div class="fb-action">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9V5.5a3.5 3.5 0 0 0-7 0V9H2v10h20V9h-8Zm-5-3.5a1.5 1.5 0 0 1 3 0V9H9V5.5Z"/></svg>
            <span>Like</span>
          </div>
          <div class="fb-action">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>Comment</span>
          </div>
          <div class="fb-action">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/></svg>
            <span>Share</span>
          </div>
        </div>
        <div class="fb-card-badge">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Published via Chukfi CMS &middot; Auto-syndicated
        </div>
      </div>
    </div>
    <div>
      <div class="unveiling-badge" style="margin-bottom: 1.5rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        FACEBOOK SYNDICATION
      </div>
      <h2 class="statement-huge" style="color: #1877F2;">Auto-Syndicate.</h2>
      <p style="font-size: 1.15rem; line-height: 1.7; opacity: 0.8; margin: 0 0 1rem; color: var(--sl-color-gray-1);">
        Publish once, distribute everywhere. The moment you approve a blog post in Chukfi, it automatically formats and syndicates to Facebook, LinkedIn, and X &mdash; complete with Open Graph tags, rich previews, and tracking links.
      </p>
      <p style="font-size: 1rem; opacity: 0.7; color: var(--sl-color-gray-2); margin: 0;">
        No copy-paste. No social media manager. One click to publish, one click to syndicate.
      </p>
    </div>
  </div>
</div>

<div class="statement-section" style="text-align: center; background: radial-gradient(circle at 50% 50%, rgba(96, 165, 250, 0.05) 0%, transparent 70%);">
  <h2 class="unveiling-title" style="font-size: clamp(2rem, 6vw, 4rem) !important; margin-bottom: 1rem;">One Command to AWS.</h2>
  <p style="font-size: 1.25rem; max-width: 600px; margin: 0 auto 3rem; opacity: 0.8; color: var(--sl-color-gray-1);">
    Provisions ECS Fargate, RDS PostgreSQL, S3, CloudFront, and SES via AWS CDK. One command, one bill, 100% Free Tier eligible.
  </p>
  <code style="font-family: var(--sl-font-mono); background: rgba(255,255,255,0.05); padding: 1rem 2rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); font-size: 1.2rem; color: var(--sl-color-accent-high);">
    npx chukfi deploy
  </code>
</div>

<div style="padding: 6rem 1rem; max-width: 900px; margin: 0 auto; text-align: center;">
  <h3 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">Explore the Technical Deep Dives</h3>
  <p style="color: var(--sl-color-gray-2); font-size: 1.05rem; margin-bottom: 2rem;">Chukfi's internal details are fully documented across our guides.</p>
  <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
    <a href="/guides/cli/" class="unveiling-cta">CLI Reference</a>
    <a href="/architecture/architecture/" class="unveiling-cta">Architecture</a>
    <a href="/teams-bot/overview/" class="unveiling-cta">Teams Bot</a>
  </div>
</div>

<div style="text-align: center; padding: 3rem 1rem 2rem; font-size: 0.85rem; color: var(--sl-color-gray-3); border-top: 1px solid rgba(255,255,255,0.03);">
  MIT Licensed &middot; <a href="https://github.com/smattera/chukfi-docs">GitHub</a> &middot; <a href="/project/roadmap/">Roadmap</a>
</div>

<script is:inline>
  let ticking = false;
  const root = document.documentElement;

  function updateParallax() {
    root.style.setProperty('--scroll-y', String(window.scrollY));
    ticking = false;
  }

  updateParallax();

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (!prefersReducedMotion.matches) {
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }, { passive: true });
  }
</script>
